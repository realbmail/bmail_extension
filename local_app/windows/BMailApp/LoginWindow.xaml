<Window x:Class="BMailApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录"
        Height="600"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/logo.ico"
        Loaded="Window_Loaded"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="White">

    <!-- 可以用一个外层Grid或Border来做圆角、阴影等效果 -->
    <Grid>
        <!-- 如果需要在WindowStyle=None时支持拖拽、关闭按钮等，可以在这里自定义标题栏 -->
        <Border Background="White"
                CornerRadius="10"
                Margin="10">
            <Grid>
                <!-- 主内容布局 -->
                <Grid x:Name="MainContent">
                    <StackPanel Margin="30" VerticalAlignment="Top">

                        <!-- 顶部图标（可替换为你设计图上的“M”图标） -->
                        <Image Source="Resources/logo.ico"
                               Width="80" Height="80"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,10"/>

                        <!-- 显示Bmail地址（示例里写死，也可以通过绑定或代码设置）-->
                        <TextBlock x:Name="BmailAddressTextBlock"
                                   Text="BMCPSXUvB4kU8GyhG4JghA83wnxq4qjuRY74SBDkaXYUoY"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <!-- 密码输入（可自定义水印/提示） -->
                        <Grid Margin="0,0,0,10">
                            <!-- 模拟水印的做法之一：在后面绑定PasswordBox的Text属性判断 -->
                            <TextBlock Text="Password"
                                       Foreground="#888"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0"
                                       IsHitTestVisible="False"/>
                            <PasswordBox x:Name="PasswordBox" 
                                         Height="36"/>
                        </Grid>

                        <!-- 登录按钮，可以给一些自定义样式 -->
                        <Button Content="登录"
                                Height="40"
                                Background="#F37B1D"
                                Foreground="White"
                                FontSize="16"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="LoginButton_Click"/>

                        <!-- 下载安装包超链接，放在右下角 -->
                        <TextBlock HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Hyperlink NavigateUri="https://mail.simplenets.org/file/extension.zip"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                下载安装包
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- 加载遮罩层 -->
                <Grid x:Name="LoadingOverlay" 
                      Background="#88000000" 
                      Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="正在登录..."
                                   Foreground="White"
                                   FontSize="18"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
