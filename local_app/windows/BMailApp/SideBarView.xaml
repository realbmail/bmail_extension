<UserControl x:Class="BMailApp.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="sidebarControl">

    <!-- 在此处定义本控件内部可用的资源，例如按钮样式 -->
    <UserControl.Resources>
        <!-- 侧边栏按钮的统一样式 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <!-- 基础属性：去边框、左对齐、字体、颜色等 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,5"/>

            <!-- 鼠标悬停时的背景高亮 -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F5F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- 主体布局：垂直堆叠 -->
    <StackPanel Orientation="Vertical" Margin="10,20,0,0" VerticalAlignment="Top">

        <!-- 示例：左侧顶部的标题。如果设计图中还有其它文字或版本信息，也可在此加入 -->
        <!-- 顶部“Enterprise Tier”带图标 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="Resources/level_gold.png"
           Width="16"
           Height="16"
           Margin="0,0,0,0"/>
            <TextBlock Text="Enterprise Tier"
               Margin="5,0,0,0"
               FontWeight="Bold"
               FontSize="16"
               Foreground="#333333"/>
        </StackPanel>


        <!-- “BMail附件”按钮：前面放 attachment.png 图标，文字“BMail附件” -->
        <Button Style="{StaticResource SidebarButtonStyle}"
                Height="44"
                Margin="0,0,0,10"
                Click="MailAttachmentButton_Click">
            <StackPanel Orientation="Horizontal">
                <Image Source="Resources/attachment.png"
                       Width="16" Height="16" Margin="0,0,8,0"/>
                <TextBlock Text="BMail附件" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- “退出登录”按钮：前面放 settings.png 图标，文字“退出登录” -->
        <Button Style="{StaticResource SidebarButtonStyle}"
                Height="44"
                Click="LogoutButton_Click">
            <StackPanel Orientation="Horizontal">
                <Image Source="Resources/setting.png"
                       Width="16" Height="16" Margin="0,0,8,0"/>
                <TextBlock Text="退出登录" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

    </StackPanel>
</UserControl>
