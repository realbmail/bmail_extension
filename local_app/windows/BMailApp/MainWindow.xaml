<Window x:Class="BMailApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BMailApp"
        Title="BMailApp" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/logo.ico"
        Loaded="Window_Loaded"
        Background="#F9FAFB">
    <!-- 整体背景，示例浅灰，可自行调整 -->

    <!-- 外层Grid，两列布局 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- 左侧导航栏宽度固定 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 中间分割线(竖线) -->
            <ColumnDefinition Width="*"/>
            <!-- 右侧内容区域 -->
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <!-- 给它一个浅色背景，与整体区分，或保持一致都行 -->
        <Border Grid.Column="0"
                Background="White" 
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,0">
            <local:SidebarView x:Name="Sidebar"
                               SelectedContent="{Binding SelectedContent, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=Window}}"
                               LogoutRequested="Sidebar_LogoutRequested"/>
        </Border>

        <!-- 中间分割线(竖线) -->
        <Border Grid.Column="1"
                Width="1"
                Background="#E0E0E0"/>
        <!-- 如果你想要一个极细的线，可以用Width="0.5"之类，或再微调颜色 -->

        <!-- 右侧内容区域 -->
        <ContentControl x:Name="ContentArea" 
                        Grid.Column="2"
                        Margin="10"
                        Background="White"/>
    </Grid>
</Window>
